{
  "version": "0.1.0",
  "name": "lending",
  "instructions": [
    {
      "name": "initialize",
      "accounts": [
        {"name": "authority", "isMut": true, "isSigner": true},
        {"name": "pool", "isMut": true, "isSigner": false}
      ],
      "args": []
    },
    {
      "name": "deposit",
      "accounts": [
        {"name": "user", "isMut": true, "isSigner": true},
        {"name": "pool", "isMut": true, "isSigner": false}
      ],
      "args": [
        {"name": "amount", "type": "u64"}
      ]
    },
    {
      "name": "withdraw",
      "accounts": [
        {"name": "user", "isMut": true, "isSigner": true},
        {"name": "pool", "isMut": true, "isSigner": false}
      ],
      "args": [
        {"name": "amount", "type": "u64"}
      ]
    }
  ],
  "accounts": [
    {
      "name": "Pool",
      "type": {
        "kind": "struct",
        "fields": [
          {"name": "total_supply", "type": "u64"},
          {"name": "rate", "type": "u64"},
          {"name": "authority", "type": "publicKey"}
        ]
      }
    }
  ]
}
